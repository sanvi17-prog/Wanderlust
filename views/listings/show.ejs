<% layout("/layout/boilerplate") %>

<div class="container mt-4">

  <!-- Heading -->
  <div class="row">
    <div class="col-12 text-center">
      <h3><%= listing.title %></h3>
    </div>
  </div>

  <!-- Card Center -->
  <div class="row justify-content-center mt-3">
    <div class="col-md-6">
      <div class="card show-card">

        <img
          src="<%= listing.image.url %>"
          class="card-img-top"
          alt="listing_image"
        />

        <div class="card-body">
          <p class="card-text">Owned By  <i><%= listing.owner.username%></i></p>

            
           <p class="card-text"> <%= listing.description %></p>
           <p class="card-text">
            &#8377;
            <%= listing.price ? listing.price.toLocaleString("en-IN") : "Not available" %></p>
            <p class="card-text"><%= listing.location %></p>
           <p class="card-text"> <%= listing.country %></p>
        
        </div>

      </div>
    </div>
  </div>

  <!-- Buttons Center -->
  <% if(currUser && listing.owner && currUser._id.toString() === listing.owner._id.toString()) { %>

<div class="row justify-content-center mt-3">
  <div class="col-md-6 d-flex justify-content-between">

    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
      Edit this Listing
    </a>

    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-dark">Delete this Listing</button>
    </form>

  </div>
</div>

<% } %>

<!-- Review Section (SEPARATE ROW) -->
<% if(currUser) {%>
<div class="row justify-content-center mt-4">
  <div class="col-md-6">
    <h4>Leave a review</h4>

    <form action="/listings/<%= listing._id %>/reviews" method="POST" >
    
        
      
      <div class="mb-3 mt-3">
       <label for="rating" class="form-label">Rating</label>
      <fieldset class="starability-slot">
        

  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
      </div>

      <div class="mb-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          rows="4"
          class="form-control"
        ></textarea>
      </div>
      <div class="invalid-feedback">Please add some comments for review

      </div>
      <button class="btn btn-dark">Submit</button>
    </form>
    <%}%>
<hr />

<%if(listing.reviews.length>0) {%>
<div class="row">
  <p>All Reviews</p>
<% for(review of listing.reviews){%>
  <div class="card col-6 ms-2 mb-3">
    <div class="card-body">
  <h5 class="card-title"><%= review.author.username%></h5>
      <p class="card-text"><%=review.comment%></p>
      
      <p class="starability-result" data-rating="<%= review.rating %>">
    Rated: <%= review.rating %> stars
</p>
      <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
        <button class="btn btn-sm btn-dark">Delete</button>
      </form>
</div>
</div>

  <%}%>
</div>
<%}%>
</div>
</div>
